# Docker build context exclusions
# This reduces build context size and speeds up builds

# Git
.git
.gitignore
.gitattributes

# IDE and Editor files
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.venv/
venv/
ENV/
env/
.env

# Virtual environments
.venv
venv
ENV
env

# Test and coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# Documentation
docs/_build
site/

# Kubernetes
.kube/
kubeconfig
*.yml~

# Logs
logs/
*.log

# Dependencies cache
node_modules/
package-lock.json
yarn.lock

# Build artifacts
dist/
build/
*.egg-info/

# Infrastructure/Terraform
.terraform/
*.tfstate
*.tfstate.*
.tfvars

# CI/CD
.github/
.gitlab-ci.yml
.circleci/

# Misc
temp/
tmp/
*.bak
*.swp
Thumbs.db

# Docker
.dockerignore
Dockerfile*
docker-compose*.yaml

# Local env files
.env.local
.env.*.local

# Block heavy archives from entering the daemon context
*.zip
*.tar.gz
*.tar

# Block local dev databases or runtime files that silently bust the cache
*.sqlite3
*.db
*.db-journal

# Block Python virtual envs (just in case they are named differently)
.tox/

# Force drop all nested virtual environments
**/venv
**/venv/
**/.venv
**/.venv/
**/env
**/env/

# Force drop all nested python cache and archives
**/__pycache__
**/*.zip
**/*.tar.gz