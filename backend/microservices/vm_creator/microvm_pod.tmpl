apiVersion: v1
kind: Pod
metadata:
  name: "{{ submission_id }}"
  namespace: "{{ namespace }}"
  labels:
    submission-id: "{{ submission_id }}"
    user-id: "{{ user_id }}"
    app: tradeforces-submission
spec:
  runtimeClassName: kata
  restartPolicy: Never
  terminationGracePeriodSeconds: 30
  
  containers:
  - name: trader
    image: "{{ docker_image }}"
    imagePullPolicy: IfNotPresent
    
    ports:
    - name: http
      containerPort: 8000
      protocol: TCP
    
    resources:
      requests:
        memory: "256Mi"
        cpu: "100m"
      limits:
        memory: "512Mi"
        cpu: "500m"
            
    env:
    - name: SUBMISSION_ID
      value: "{{ submission_id }}"
    - name: USER_ID
      value: "{{ user_id }}"
    - name: POD_NAMESPACE
      valueFrom:
        fieldRef:
          fieldPath: metadata.namespace
    - name: POD_NAME
      valueFrom:
        fieldRef:
          fieldPath: metadata.name
    - name: POD_IP
      valueFrom:
        fieldRef:
          fieldPath: status.podIP
  
  affinity:
    podAntiAffinity:
      preferredDuringSchedulingIgnoredDuringExecution:
      - weight: 100
        podAffinityTerm:
          labelSelector:
            matchExpressions:
            - key: app
              operator: In
              values:
              - tradeforces-submission
          topologyKey: kubernetes.io/hostname